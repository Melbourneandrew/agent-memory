{
  "name": "@melbourneandrew/agent-memory-cli",
  "version": "0.1.1",
  "description": "Agent Memory: CLI, shared runtime, and local web UI for Backboard.",
  "keywords": [
    "cli",
    "command-line",
    "agent-memory",
    "backboard",
    "memory",
    "nextjs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Melbourneandrew/agent-memory.git"
  },
  "bugs": {
    "url": "https://github.com/Melbourneandrew/agent-memory/issues"
  },
  "homepage": "https://github.com/Melbourneandrew/agent-memory#readme",
  "private": false,
  "bin": {
    "agent-memory": "cli/dist/bin.js"
  },
  "files": [
    "cli/dist",
    "webui"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "backboard-sdk": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "workspaces": [
    "core",
    "cli",
    "webui"
  ],
  "scripts": {
    "build": "npm run build --workspace @agent-memory-cli/core && npm run build --workspace @agent-memory/webui && npm run build --workspace @agent-memory-cli/cli",
    "test": "npm run test --workspace @agent-memory-cli/core && npm run test --workspace @agent-memory-cli/cli && npm run test --workspace @agent-memory/webui --if-present",
    "lint": "npm run lint --workspace @agent-memory-cli/core && npm run lint --workspace @agent-memory-cli/cli && npm run lint --workspace @agent-memory/webui",
    "lint:staged": "lint-staged",
    "format": "npm run format --workspace @agent-memory-cli/core && npm run format --workspace @agent-memory-cli/cli && npm run format --workspace @agent-memory/webui --if-present",
    "format:check": "prettier --check \"*.{json,md,yml,yaml}\" \"{core,cli,webui,docs,.github}/**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "precommit": "npm run lint:staged",
    "prepush": "npm run lint && npm run test && npm run build",
    "prepare": "node -e \"const fs=require('fs');const{execSync}=require('child_process');if(fs.existsSync('.git')){try{execSync('husky',{stdio:'inherit'})}catch(e){process.exit(0)}}\""
  },
  "lint-staged": {
    "core/src/**/*.ts": [
      "npm run lint --workspace @agent-memory-cli/core -- --fix",
      "prettier --write"
    ],
    "cli/{src,tests}/**/*.ts": [
      "npm run lint --workspace @agent-memory-cli/cli -- --fix",
      "prettier --write"
    ],
    "webui/**/*.{js,ts,tsx}": [
      "npm run lint --workspace @agent-memory/webui --",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write",
    "{docs,.github}/**/*.{md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
